# OpenAI
OPENAI_API_KEY=

# Anthropic (optional, for claude models)
# ANTHROPIC_API_KEY=

# Google (optional, for gemini models)
# GOOGLE_API_KEY=

# Chatbot models — use "provider:model" format for any LangChain-supported provider:
#   openai:gpt-4o
#   anthropic:claude-3-5-sonnet-20241022
#   google_genai:gemini-2.0-flash
#   ollama:llama3  (local, no API key needed)
CHATBOT_MODEL_GENERATIVE=openai:gpt-4o

# Embedding model — NOTE: changing this requires re-embedding all Milvus data
# Dimension must match the Milvus collection schema (default: 3072 for text-embedding-3-large)
CHATBOT_MODEL_EMBEDDING=text-embedding-3-large

# Milvus vector database
MILVUS_IP=localhost

# Langfuse observability (https://langfuse.com)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
